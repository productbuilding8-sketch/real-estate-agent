# ── Root .env.example ─────────────────────────────────────────────────────────
# Copy to .env and fill values. Never commit .env to git.

# Postgres
DATABASE_URL=postgresql+asyncpg://dealflow:dealflow@localhost:5432/dealflow

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.dealflow.ai
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# App
SECRET_KEY=                   # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENVIRONMENT=development        # development | staging | production
LOG_LEVEL=INFO
